{
	"name": "notes",
	"version": "1.0.0",
	"scripts": {
		"dev": "vite dev",
		"build": "prisma generate && vite build",
		"build:migrate": "prisma generate && prisma migrate deploy && vite build",
		"build:tsc": "tsc --noEmit",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run --coverage",
		"test:unit": "vitest",
		"test:playwright": "playwright test",
		"lint": "prettier . --check . && eslint .",
		"lint-staged": "lint-staged",
		"format": "prettier . --write .",
		"prepare": "husky",
		"postinstall": "prisma generate"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.6",
		"@eslint/js": "10.0.1",
		"@faker-js/faker": "10.5.0",
		"@fontsource/fira-mono": "5.3.0",
		"@neoconfetti/svelte": "2.2.2",
		"@playwright/test": "1.61.1",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/adapter-vercel": "6.3.4",
		"@sveltejs/kit": "2.70.1",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "4.3.3",
		"@types/node": "26.1.1",
		"@typescript-eslint/eslint-plugin": "8.65.0",
		"@typescript-eslint/parser": "8.65.0",
		"@vitest/coverage-v8": "4.1.10",
		"eslint": "10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.22.0",
		"globals": "17.7.0",
		"husky": "9.1.7",
		"lint-staged": "17.1.1",
		"postcss": "8.5.22",
		"prettier": "3.9.6",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.1",
		"prisma": "6.19.3",
		"svelte": "5.56.7",
		"svelte-check": "4.7.3",
		"svelte-eslint-parser": "1.8.0",
		"tailwindcss": "4.3.3",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"vite": "8.1.5",
		"vitest": "4.1.10"
	},
	"type": "module",
	"dependencies": {
		"@auth0/auth0-spa-js": "2.24.0",
		"@aws-sdk/client-ses": "3.1093.0",
		"@lucide/svelte": "1.25.0",
		"@prisma/client": "6.19.3",
		"@tiptap/core": "3.28.0",
		"@tiptap/extension-hard-break": "3.28.0",
		"@tiptap/extension-placeholder": "3.28.0",
		"@tiptap/extension-underline": "3.28.0",
		"@tiptap/pm": "3.28.0",
		"@tiptap/starter-kit": "3.28.0",
		"bits-ui": "2.18.1",
		"idb-keyval": "6.3.0",
		"jose": "6.2.4",
		"nanoid": "6.0.0",
		"neverthrow": "8.2.0",
		"prisma-field-encryption": "1.6.0",
		"svelte-sonner": "1.1.1",
		"zod": "4.4.3"
	},
	"lint-staged": {
		"*": [
			"prettier . --write",
			"eslint ."
		]
	},
	"engines": {
		"node": "24.x"
	},
	"packageManager": "pnpm@11.16.0"
}
