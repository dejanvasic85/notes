{
	"name": "notes",
	"version": "1.0.0",
	"scripts": {
		"dev": "vite dev",
		"build": "prisma generate && vite build",
		"build:migrate": "prisma generate && prisma migrate deploy && vite build",
		"build:tsc": "tsc --noEmit",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run --coverage",
		"test:unit": "vitest",
		"test:playwright": "playwright test",
		"lint": "prettier . --check . && eslint .",
		"lint-staged": "lint-staged",
		"format": "prettier . --write .",
		"prepare": "husky",
		"postinstall": "prisma generate"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@faker-js/faker": "10.4.0",
		"@fontsource/fira-mono": "5.2.7",
		"@melt-ui/pp": "0.3.2",
		"@melt-ui/svelte": "0.86.6",
		"@neoconfetti/svelte": "2.2.2",
		"@playwright/test": "1.61.0",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/adapter-vercel": "6.3.3",
		"@sveltejs/kit": "2.65.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "4.3.1",
		"@types/node": "25.9.3",
		"@typescript-eslint/eslint-plugin": "8.61.1",
		"@typescript-eslint/parser": "8.61.1",
		"@vitest/coverage-v8": "4.1.9",
		"eslint": "10.5.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.19.0",
		"globals": "17.6.0",
		"husky": "9.1.7",
		"lint-staged": "17.0.7",
		"postcss": "8.5.15",
		"prettier": "3.8.4",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"prisma": "6.19.3",
		"svelte": "5.56.3",
		"svelte-check": "4.6.0",
		"tailwindcss": "4.3.1",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.9"
	},
	"type": "module",
	"dependencies": {
		"@auth0/auth0-spa-js": "2.21.1",
		"@aws-sdk/client-ses": "3.1069.0",
		"@prisma/client": "6.19.3",
		"@tiptap/core": "3.26.1",
		"@tiptap/extension-hard-break": "3.26.1",
		"@tiptap/extension-placeholder": "3.26.1",
		"@tiptap/pm": "3.26.1",
		"@tiptap/starter-kit": "3.26.1",
		"jose": "6.2.3",
		"nanoid": "5.1.11",
		"neverthrow": "8.2.0",
		"prisma-field-encryption": "1.6.0",
		"zod": "4.4.3"
	},
	"lint-staged": {
		"*": [
			"prettier . --write",
			"eslint ."
		]
	},
	"engines": {
		"node": "24.x"
	},
	"volta": {
		"node": "24.16.0",
		"npm": "11.17.0"
	}
}
